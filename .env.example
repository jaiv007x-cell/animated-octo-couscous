# Optional. Without OpenAI, the bot still works with extractive answers and citations.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Monitoring behavior
DATABASE_URL=sqlite:///./storage/excisewatch.db
SOURCE_CONFIG_PATH=./data/sources.yaml
SNAPSHOT_DIR=./storage/snapshots
DOC_DIR=./storage/docs
HTTP_TIMEOUT_SECONDS=25
USER_AGENT=ExciseWatchBot/0.1 compliance-monitoring; contact=your-email@example.com

# Alerts. Leave blank to disable.
SLACK_WEBHOOK_URL=

# Telegram setup:
# 1) Create bot with @BotFather and paste token below.
# 2) Add bot to a Telegram channel/group.
# 3) Put channel username like @YourChannel or numeric chat_id below.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PARSE_MODE=
TELEGRAM_DISABLE_WEB_PAGE_PREVIEW=true
TELEGRAM_DIGEST_LIMIT=25
TELEGRAM_INCLUDE_CHATTER_BY_DEFAULT=false
TELEGRAM_MIN_TIER=REPORTED_NOT_CONFIRMED

EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_TO=

# v6 production hardening
JWT_SECRET_KEY=replace-with-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=720
SCHEDULER_ENABLED=false
REVIEW_REQUIRED_FOR_OFFICIAL=true
AUTO_ALERT_OFFICIAL=false
CHATTER_PRIVATE_ONLY=true
SOURCE_LIVE_FETCH_DEFAULT=false
SOURCE_VALIDATION_MAX_SOURCES=200
COMPLIANCE_MIN_OFFICIAL_SOURCES=1
# PostgreSQL production example:
# DATABASE_URL=postgresql://excisewatch:strongpassword@postgres:5432/excisewatch
